@model CityWeather

@if(Model != null)
{
    string temperatureClass = "";
    @if(ViewBag.ColorNode != null)
    {
        string GetTemperature(int InTemperature)
        {
            return InTemperature switch
            {
                < 44 => "blue-back",
                >= 44 and < 75 => "green-back",
                >= 75 => "orange-back",
            };
        }
        temperatureClass = GetTemperature(Model.TemperatureFahrenheit);
    }
    <div class="box cursor-pointer w-30 @temperatureClass">
        <div class="flex-borderless">
            <div class="w-50">
                <h2>@Model.CityName</h2>
                @if(ViewBag.ColorNode != null)
                {
                    <h4 class="text-dark-grey">@Model.DateAndTime.ToString("hh:mm tt")</h4>
                    <a href="~/weather/@Model.CityUniqueCode" class="margin-top">Details</a>
                }
                else
                {
                    <h4 class="text-dark-grey">@Model.DateAndTime.ToString("dd MMM, yyyy")</h4>
                    <h4 class="text-dark-grey">@Model.DateAndTime.ToString("hh:mm tt")</h4>
                }
            </div>
            <div class="w-50 border-left">
                <h1 class="margin-left">@Model.TemperatureFahrenheit <sup class="text-grey">&#8457</sup></h1>
            </div>
        </div>
    </div>
}
else
{
    <h3>City Code is not valid.</h3>
}