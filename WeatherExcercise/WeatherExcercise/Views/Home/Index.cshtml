@using WeatherExcercise.Models;
@model List<CityWeather>
<!DOCTYPE html>
<html>
    <head>
        <title>Weather Exercise</title>
        <meta charset="UTF-8" />
        <style>
            h3
            {
                font-size: 28px !important;
                line-height: 0.7;
                font-weight: 700;
            }
            .weather_node_wrapper
            {
                width: 100%;
                display: flex;
                flex-wrap: nowrap;
                justify-content: space-between;
                align-items: center;
            }
            .weather_node
            {
                width: 25%;
                height: 100px;
                border: 1px solid #404040;
                display: flex;
                flex-direction: row;
                justify-content: space-between;
                align-items: center;
                padding: 2rem;

            }
            .weather_meta
            {
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: flex-start;
                width: 55%;
                padding-right: 1rem;
                border-right: solid 1px #404040;
            }
            .weather_fahrenheit
            {
                font-size: 26px;
                font-weight: 600;
            }
        </style>
    </head>
    <body>
        <h1>Weather</h1>
        <div class="weather_node_wrapper">
            @foreach(CityWeather cityWeather in Model)
            {
                string temperatureColor = cityWeather.TemperatureFahrenheit switch
                {
                    < 32 => "#0143f5",
                    >= 32 and < 50 => "#01a9f5",
                    >= 50 and < 70 => "#01f5d1",
                    >= 70 and < 90 => "#f5e801",
                    >= 90 => "#f54301",
                };
                <div class="weather_node" data-for="@cityWeather.CityName" style="background-color: @temperatureColor">
                    <div class="weather_meta">
                        <h3>@cityWeather.CityName</h3>
                        <p style="margin-bottom: 1rem;">@cityWeather.DateAndTime.ToString("H:mm")</p>
                        <a href="/weather/@cityWeather.CityUniqueCode">Details</a>
                    </div>
                    <div class="weather_details">
                        <p class="weather_fahrenheit">
                            @cityWeather.TemperatureFahrenheit &deg;F
                        </p>
                    </div>
                </div>
            }
        </div>
    </body>
</html>