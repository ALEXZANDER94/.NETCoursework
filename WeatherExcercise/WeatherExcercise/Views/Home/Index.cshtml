@model List<CityWeather>

@{
    string GetTemperature(int InTemperature)
    {
        return InTemperature switch
        {
            < 44 => "blue-back",
            >= 44 and < 75 => "green-back",
            >= 75 => "orange-back",
        };
    }
}
    <div class="margin-top-200 margin-left">
        <div class="flex">
            @foreach(CityWeather cityWeather in Model)
            {
                ViewBag.ColorNode = true;
                @await Component.InvokeAsync("WeatherNode", new { city = cityWeather })
            }
        </div>
    </div>